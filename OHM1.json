      "range": {
        "min": 0,
        "max": 1
      },
      "summary": {
        "meanFormat": "pct",
        "p10p90Format": "pct"
      }
    },
    {
      "id": "coherence",
      "title": "Cross-jurisdiction coherence probability",
      "subtitle": "Likelihood that local implementations remain meaningfully aligned with the enterprise standard across law, culture, and reporting.",
      "units": "probability",
      "range": {
        "min": 0,
        "max": 1
      },
      "summary": {
        "meanFormat": "pct",
        "p10p90Format": "pct"
      }
    },
    {
      "id": "harmAvoidance",
      "title": "Preventable harm avoidance probability",
      "subtitle": "Proxy probability of averting the main OH failure modes in the scenario: hearing loss, contractor asthma, MSD escalation, and psychosocial deterioration.",
      "units": "probability",
      "range": {
        "min": 0,
        "max": 1
      },
      "summary": {
        "meanFormat": "pct",
        "p10p90Format": "pct"
      }
    },
    {
      "id": "assuranceContinuity",
      "title": "Assurance & continuity probability",
      "subtitle": "Likelihood that the OH system supports investor/regulator assurance and operational continuity instead of merely producing transactional reports.",
      "units": "probability",
      "range": {
        "min": 0,
        "max": 1
      },
      "summary": {
        "meanFormat": "pct",
        "p10p90Format": "pct"
      }
    }
  ],
