  "parameters": [
    {
      "id": "jurisdictionDivergence",
      "label": "Jurisdiction divergence",
      "hint": "How far local OH&S requirements differ across sites. High values increase legal and assurance fragmentation.",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 70
    },
    {
      "id": "corporateMinimumStrength",
      "label": "Corporate minimum strength",
      "hint": "How clearly OneHealth defines and enforces non-negotiable global minima across jurisdictions.",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 72
    },
    {
      "id": "contractorEquivalence",
      "label": "Contractor equivalent protection",
      "hint": "How fully contractor workers receive protections equivalent to direct employees on high-risk work.",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 48
    },
    {
      "id": "exposureBaselineCurrency",
      "label": "Exposure baseline currency",
      "hint": "How current and comparable exposure baselines/noise maps/hygiene surveys are across the network.",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 44
    },
    {
      "id": "surveillanceCoverage",
      "label": "Risk-based surveillance coverage",
      "hint": "Extent to which exposed groups are enrolled in hazard-linked surveillance rather than generic annual medicals.",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 52
    },
    {
      "id": "fitnessCoverage",
      "label": "Critical-role fitness coverage",
      "hint": "Coverage and quality of fitness-for-work assessment for safety-critical roles.",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 68
    },
    {
      "id": "workerParticipation",
      "label": "Worker participation strength",
      "hint": "Degree of worker consultation, speak-up channels, and practical involvement in OH control design.",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 55
    },
    {
      "id": "professionalIndependence",
      "label": "Professional independence",
      "hint": "Freedom of OH clinicians/hygienists to make risk judgments without operational suppression.",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 58
    },
    {
      "id": "multidisciplinaryIntegration",
      "label": "Multidisciplinary OH integration",
      "hint": "How well clinicians, industrial hygienists, ergonomists, HR, and operations work as a joined system.",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 50
    },
    {
      "id": "culturalCoherence",
      "label": "Cultural coherence",
      "hint": "How well the corporate standard is translated into locally meaningful practice across language, hierarchy, and norms.",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 46
    },
    {
      "id": "mentalHealthReportingClimate",
      "label": "Mental-health reporting climate",
      "hint": "Psychological safety for reporting stress, bullying, sleep disruption, and related psychosocial symptoms.",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 42
    },
    {
      "id": "profitPressure",
      "label": "Profitability pressure",
      "hint": "Pressure to prioritize throughput/cost over slower OH systems work. High values worsen risk governance.",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 78
    },
    {
      "id": "transactionalReporting",
      "label": "Transactional reporting dominance",
      "hint": "How far OH is judged by certificates, case closure, and cost metrics instead of exposure/risk control.",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 76
    },
    {
      "id": "ohResourcing",
      "label": "OH resourcing",
      "hint": "Capacity available for strategic OH work beyond routine certification and clinic administration.",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 47
    },
    {
      "id": "remediationDiscipline",
      "label": "Corrective-action discipline",
      "hint": "How reliably overdue hygiene, ergonomic, psychosocial, and contractor actions are tracked and completed.",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 54
    },
    {
      "id": "draws",
      "label": "Monte Carlo draws",
      "hint": "Number of model draws per simulation.",
      "min": 1000,
      "max": 15000,
      "step": 500,
      "default": 5000,
      "isMeta": true
    },
    {
      "id": "debounce",
      "label": "Debounce (ms)",
      "hint": "Delay before recomputing while sliders move.",
      "min": 0,
      "max": 300,
      "step": 20,
      "default": 60,
      "isMeta": true
    }
  ],
  "outputs": [
